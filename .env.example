# ============================================
# FFCES Production Environment Configuration
# ============================================
# Copy this file to .env and update values for production
#   cp .env.example .env
#
# NEVER commit the .env file to version control!
# ============================================

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DB_PASSWORD=ffces_pass_change_me

# -------------------------------------------
# Security
# -------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=generate-a-secure-random-key-here

# Token expiration settings
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------------------------------
# Redis (optional password)
# -------------------------------------------
# Leave empty to disable authentication
REDIS_PASSWORD=

# -------------------------------------------
# MinIO Object Storage
# -------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me

# -------------------------------------------
# Domain & CORS
# -------------------------------------------
# Set to your production domain (without protocol)
ALLOWED_DOMAIN=your-domain.com
