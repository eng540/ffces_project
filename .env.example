# FFCES Environment Configuration
DATABASE_URL=postgresql+asyncpg://ffces_user:ffces_pass@localhost:5432/ffces_db
REDIS_URL=redis://localhost:6379
SECRET_KEY=your-secret-key-here-min-32-chars
DEBUG=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ffces-attachments

# Approval Thresholds
EXPENSE_APPROVAL_THRESHOLD=1000
CUSTODY_APPROVAL_THRESHOLD=2000
PAYMENT_APPROVAL_THRESHOLD=1000
