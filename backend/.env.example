# ============================================
# FFCES - Field Financial Custody & Entitlements System
# ============================================
# قالب ملف المتغيرات البيئية

# Database - PostgreSQL
DATABASE_URL=postgresql+asyncpg://ffces_user:ffces_pass@localhost:5432/ffces_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ffces-documents
MINIO_SECURE=false

# Application
DEBUG=true

# Approval Thresholds (in SAR)
APPROVAL_LEVEL1_THRESHOLD=10000
APPROVAL_LEVEL2_THRESHOLD=50000
APPROVAL_LEVEL3_THRESHOLD=100000
